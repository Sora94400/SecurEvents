{% extends 'base.html.twig' %}

{% block title %}Détails de l'événement{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto mt-10 px-4">
    
    {# 1. Bouton Retour #}
    <div class="mb-6">
        <a href="{{ path('app_events_catalog') }}" class="text-slate-400 hover:text-white transition flex items-center gap-2">
            &larr; Retour au catalogue
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        {# COLONNE GAUCHE : Infos de l'événement #}
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-slate-900 border border-slate-700 rounded-3xl p-8 shadow-2xl">
                <span class="text-amber-500 font-bold tracking-widest uppercase text-xs">
                    {{ event.category ? event.category.nom : 'Général' }}
                </span>
                <h1 class="text-4xl font-black text-white mt-2 mb-6">{{ event.titre }}</h1>
                
                <div class="prose prose-invert max-w-none text-slate-300 mb-8">
                    {{ event.description|nl2br }}
                </div>

                <div class="flex flex-wrap gap-6 text-sm text-slate-400 border-t border-slate-800 pt-6">
                    <div>📅 <span class="text-white ml-1">{{ event.dateDebut|date('d/m/Y H:i') }}</span></div>
                    <div>📍 <span class="text-white ml-1">{{ event.lieu }}</span></div>
                    <div>👥 <span class="text-white ml-1">{{ event.reservations|length }} / {{ event.capaciteMax }} places</span></div>
                </div>
            </div>

            {# --- BLOC ITINERAIRE (GOOGLE MAPS) --- #}
            <div class="bg-slate-800/50 border border-slate-700 rounded-3xl p-8 shadow-xl">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 bg-blue-500/20 rounded-lg flex items-center justify-center text-blue-500 text-xl">📍</div>
                    <h3 class="text-xl font-bold text-white">Calculer votre itinéraire</h3>
                </div>

                <form action="https://www.google.com/maps/dir/" target="_blank" method="get" class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase mb-2">Votre point de départ</label>
                        <input type="text" name="saddr" 
                               value="{{ app.user and app.user.adresse ? app.user.adresse : '' }}" 
                               placeholder="Ville ou adresse précise..."
                               class="w-full bg-slate-900 border border-slate-600 rounded-xl p-3 text-white focus:border-blue-500 outline-none transition"
                               required>
                    </div>
                    
                    {# Destination automatique #}
                    <input type="hidden" name="daddr" value="{{ event.lieu }}">
                    
                    <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 px-6 rounded-xl transition flex items-center justify-center gap-2">
                        Calculer sur Google Maps
                    </button>
                </form>
            </div>
        </div>

        {# COLONNE DROITE : Inscription #}
        <div class="space-y-6">
            <div class="bg-slate-900 border border-slate-700 rounded-3xl p-8 sticky top-10">
                <h3 class="text-xl font-bold text-white mb-6">Inscription</h3>
                
                {% if app.user %}
                    {% if dejaInscrit %}
                        <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-500 p-4 rounded-xl text-center font-medium">
                            ✓ Vous êtes inscrit
                        </div>
                    {% elseif event.reservations|length >= event.capaciteMax %}
                        <div class="bg-red-500/10 border border-red-500/20 text-red-500 p-4 rounded-xl text-center font-medium">
                            Désolé, l'événement est complet.
                        </div>
                    {% else %}
                        <form action="{{ path('app_event_inscrire', {id: event.id}) }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('inscrire' ~ event.id) }}">
                            <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-slate-950 font-black py-4 px-6 rounded-xl transition shadow-lg shadow-amber-500/20">
                                S'inscrire maintenant
                            </button>
                        </form>
                    {% endif %}
                {% else %}
                    <a href="{{ path('app_login') }}" class="block w-full bg-slate-800 hover:bg-slate-700 text-white text-center font-bold py-4 px-6 rounded-xl transition">
                        Connectez-vous pour participer
                    </a>
                {% endif %}
            </div>
        </div>

    </div>
</div>
{% endblock %}