{% extends 'base.html.twig' %}

{% block title %}Créer un événement{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <a href="{{ path('app_admin_events') }}" class="text-slate-400 hover:text-white text-sm transition">← Retour à la liste</a>
        <h1 class="text-3xl font-bold text-white mt-2">Créer un événement</h1>
    </div>

    <div class="bg-slate-900 border border-slate-700 p-6 rounded-xl shadow-xl">
        {{ form_start(form) }}
            <div class="space-y-4">
                {# On laisse Twig rendre les champs avec le style par défaut de Symfony #}
                {# Tu pourras personnaliser le rendu des champs plus tard #}
                {{ form_widget(form) }}
                
                <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-white font-bold py-3 px-4 rounded-lg transition mt-6">
                    Enregistrer l'événement
                </button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
