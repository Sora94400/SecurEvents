{% extends 'base.html.twig' %}

{% block title %}Gestion des événements - Admin{% endblock %}

{% block body %}
<div class="space-y-6">
    <div class="flex justify-between items-center">
        <h1 class="text-3xl font-bold text-white">Gestion des Événements</h1>
        <a href="{{ path('app_admin_event_new') }}" class="bg-amber-500 hover:bg-amber-600 text-white px-4 py-2 rounded-lg font-medium transition shadow-lg shadow-amber-500/20">
            + Nouvel événement
        </a>
    </div>

    <div class="bg-slate-900 border border-slate-700 rounded-xl overflow-hidden shadow-2xl">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-800 text-slate-300 text-sm uppercase tracking-wider">
                    <th class="p-4 border-b border-slate-700">Titre</th>
                    <th class="p-4 border-b border-slate-700">Date</th>
                    <th class="p-4 border-b border-slate-700">Lieu</th>
                    <th class="p-4 border-b border-slate-700 text-center">Statut</th>
                    <th class="p-4 border-b border-slate-700 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-700">
                {% for event in events %}
                    <tr class="hover:bg-slate-800/50 transition">
                        <td class="p-4 text-white font-medium">{{ event.titre }}</td>
                        <td class="p-4 text-slate-400 text-sm">{{ event.dateDebut|date('d/m/Y H:i') }}</td>
                        <td class="p-4 text-slate-400 text-sm">{{ event.lieu }}</td>
                        <td class="p-4 text-center">
                            {% if event.isPublished %}
                                <span class="bg-emerald-500/10 text-emerald-400 text-xs px-2 py-1 rounded border border-emerald-500/20">Publié</span>
                            {% else %}
                                <span class="bg-slate-700 text-slate-400 text-xs px-2 py-1 rounded border border-slate-600">Brouillon</span>
                            {% endif %}
                        </td>
                        <td class="p-4 text-right flex justify-end gap-4">
                            <a href="{{ path('app_admin_event_edit', {id: event.id}) }}" class="text-amber-400 hover:text-amber-300 text-sm font-medium">Modifier</a>
                            
                            <form method="post" action="{{ path('app_admin_event_delete', {id: event.id}) }}" onsubmit="return confirm('Supprimer cet événement ?');" class="inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                                <button class="text-red-400 hover:text-red-300 text-sm font-medium bg-transparent border-none p-0 cursor-pointer">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="p-8 text-center text-slate-500 italic">Aucun événement trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}