{% use "form_div_layout.html.twig" %}

{% block form_label %}
    {% set label_attr = label_attr|merge({ class: (label_attr.class|default('') ~ ' block text-sm font-medium text-slate-300 mb-2')|trim }) %}
    {{ parent() }}
{% endblock %}

{% block form_errors %}
    {% if errors|length > 0 %}
        <ul class="mt-1 text-sm text-red-400">
            {% for error in errors %}
                <li>{{ error.message }}</li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
