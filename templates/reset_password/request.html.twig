{% extends 'base.html.twig' %}

{% block title %}{{ 'reset.title'|trans|default('Réinitialiser le mot de passe') }}{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto bg-slate-900 border border-slate-700 p-8 rounded-2xl shadow-xl mt-10">
        <h1 class="text-2xl font-bold text-amber-400 mb-6 text-center">
            {{ 'reset.password_request_title'|trans|default('Réinitialisation') }}
        </h1>

        {{ form_start(requestForm) }}
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-300 mb-1">Votre adresse email</label>
                    {{ form_widget(requestForm.email, {
                        'attr': {
                            'class': 'w-full bg-slate-800 border border-slate-600 rounded-lg py-2 px-4 text-white focus:ring-2 focus:ring-amber-400 focus:border-transparent outline-none transition'
                        }
                    }) }}
                </div>

                <div class="text-sm text-slate-400 py-2">
                    Entrez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.
                </div>

                <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-slate-950 font-bold py-2 px-4 rounded-lg transition duration-200">
                    Envoyer l'email
                </button>
            </div>
        {{ form_end(requestForm) }}
    </div>
{% endblock %}
