{% extends 'base.html.twig' %}

{% block title %}Mes événements - SecureEvents{% endblock %}

{% block content %}
<h1 class="text-2xl font-bold text-amber-400 mb-6">Mes événements</h1>

{% if events is empty %}
    <div class="text-center py-16 bg-slate-800/30 rounded-xl border border-slate-700">
        <p class="text-slate-400 text-lg">Vous n'êtes inscrit à aucun événement.</p>
        <a href="{{ path('app_home') }}" class="mt-4 inline-block text-amber-400 hover:text-amber-300">Découvrir les événements</a>
    </div>
{% else %}
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {% for event in events %}
            <article class="bg-slate-800/50 border border-slate-600 rounded-xl p-6">
                <h2 class="text-lg font-semibold text-white mb-2">{{ event.titre }}</h2>
                <div class="space-y-1 text-sm text-slate-500">
                    <p>📅 {{ event.dateDebut|date('d/m/Y H:i') }}</p>
                    <p>📍 {{ event.lieu }}</p>
                </div>
                <a href="{{ path('app_event_show', { id: event.id }) }}" class="mt-3 inline-block text-amber-400 hover:text-amber-300 text-sm">
                    Voir les détails →
                </a>
            </article>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
