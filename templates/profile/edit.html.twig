{% extends 'base.html.twig' %}

{% block title %}Mon profil - SecurEvent{% endblock %}

{% block content %}
<h1 class="text-2xl font-bold text-amber-400 mb-6">Mon profil</h1>

<div class="max-w-xl bg-slate-800/50 border border-slate-600 rounded-xl p-6">
    {{ form_start(form) }}
        {{ form_row(form.email) }}
        {{ form_row(form.prenom) }}
        {{ form_row(form.nom) }}

        <button type="submit" class="mt-4 px-4 py-2 rounded-lg bg-amber-500 hover:bg-amber-600 text-slate-900 font-medium">
            Enregistrer
        </button>
    {{ form_end(form) }}
</div>
{% endblock %}
