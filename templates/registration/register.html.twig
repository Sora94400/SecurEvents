{% extends 'base.html.twig' %}

{% block title %}Inscription - SecureEvents{% endblock %}

{% block content %}
<div class="min-h-[70vh] flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
        <div class="bg-slate-800/50 backdrop-blur border border-slate-600 rounded-2xl shadow-xl p-8">
            <h1 class="text-2xl font-bold text-amber-400 mb-6 text-center">Inscription</h1>

            {% for message in app.flashes('success') %}
                <div class="mb-4 p-3 bg-emerald-500/20 border border-emerald-500/50 rounded-lg text-emerald-300 text-sm">
                    {{ message }}
                </div>
            {% endfor %}

            {{ form_start(registrationForm, { 'attr': { 'class': 'space-y-5' } }) }}
                {{ form_row(registrationForm.email) }}
                {{ form_row(registrationForm.plainPassword) }}

                <button type="submit"
                        class="w-full py-3 px-4 rounded-lg font-medium bg-amber-500 hover:bg-amber-600 text-slate-900 transition">
                    S'inscrire
                </button>
            {{ form_end(registrationForm) }}

            <p class="mt-6 text-center text-slate-400 text-sm">
                Déjà un compte ?
                <a href="{{ path('app_login') }}" class="text-amber-400 hover:text-amber-300 font-medium">Se connecter</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
