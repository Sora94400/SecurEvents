{% extends 'base.html.twig' %}

{% block title %}Connexion - SecureEvents{% endblock %}

{% block content %}
<div class="min-h-[70vh] flex items-center justify-center px-4">
    <div class="w-full max-w-md">
        <div class="bg-slate-800/50 backdrop-blur border border-slate-600 rounded-2xl shadow-xl p-8">
            <h1 class="text-2xl font-bold text-amber-400 mb-6 text-center">Connexion</h1>

            {% if error %}
                <div class="mb-4 p-3 bg-red-500/20 border border-red-500/50 rounded-lg text-red-300 text-sm">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post" action="{{ path('app_login') }}" class="space-y-5">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div>
                    <label for="email" class="block text-sm font-medium text-slate-300 mb-2">Email</label>
                    <input type="email"
                           id="email"
                           name="email"
                           value="{{ last_username }}"
                           required
                           autofocus
                           class="w-full px-4 py-2 rounded-lg bg-slate-700/50 border border-slate-600 text-slate-100 placeholder-slate-400 focus:ring-2 focus:ring-amber-500 focus:border-amber-500 outline-none transition">
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-slate-300 mb-2">Mot de passe</label>
                    <input type="password"
                           id="password"
                           name="password"
                           required
                           class="w-full px-4 py-2 rounded-lg bg-slate-700/50 border border-slate-600 text-slate-100 placeholder-slate-400 focus:ring-2 focus:ring-amber-500 focus:border-amber-500 outline-none transition">
                </div>

                <button type="submit"
                        class="w-full py-3 px-4 rounded-lg font-medium bg-amber-500 hover:bg-amber-600 text-slate-900 transition">
                    Se connecter
                </button>
            </form>

            <p class="mt-6 text-center text-slate-400 text-sm">
                Pas encore de compte ?
                <a href="{{ path('app_register') }}" class="text-amber-400 hover:text-amber-300 font-medium">S'inscrire</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
